	file = {Preprint PDF:/Users/adamdong/Zotero/storage/RHD6544N/Spooner and Savani - 2020 - Robust Market Making via Adversarial Reinforcement Learning.pdf:application/pdf},
}

@misc{ganesh_reinforcement_2019,
	title = {Reinforcement {Learning} for {Market} {Making} in a {Multi}-agent {Dealer} {Market}},
	url = {http://arxiv.org/abs/1911.05892},
